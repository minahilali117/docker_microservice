#!/usr/bin/env node

const { port } = require('../config');

const app = require('../app');
const db = require('../db/models');

async function bootstrapDatabase() {
  await db.sequelize.authenticate();
  await db.sequelize.sync();

  const orderCount = await db.Order.count();
  if (orderCount === 0) {
    await db.Order.bulkCreate([
      { customerId: 1, placedOn: new Date(2020, 5, 1, 8, 12), status: 'pending', totalAmount: 0 },
      { customerId: 1, placedOn: new Date(2020, 5, 11, 10, 34), status: 'pending', totalAmount: 0 },
      { customerId: 2, placedOn: new Date(2020, 3, 5, 14, 44), status: 'pending', totalAmount: 0 },
    ]);
  }
}

bootstrapDatabase()
  .then(() => {
    console.log('Database connection success! Sequelize is ready to use...');
    app.listen(port, () => console.log(`Listening on port ${port}...`));
  })
  .catch((err) => {
    console.log('Database connection failure.');
    console.error(err);
    process.exit(1);
  });
